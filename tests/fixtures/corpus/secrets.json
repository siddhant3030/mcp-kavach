{
  "description": "Credentials in tool output. All values are documentation examples, not live secrets.",
  "tool": "get_config",
  "direction": "result",
  "policy": "ngo-default",
  "payload": {
    "config": {
      "aws_key_id": "AKIAIOSFODNN7EXAMPLE",
      "note": "rotate token ghp_AbCdEfGhIjKlMnOpQrStUvWxYz0123456789 next week",
      "endpoint": "10.0.0.12"
    }
  },
  "expected": [
    { "path": "$.config.aws_key_id", "entity_type": "AWS_ACCESS_KEY", "action": "block" },
    { "path": "$.config.note", "entity_type": "GITHUB_TOKEN", "action": "block" },
    { "path": "$.config.endpoint", "entity_type": "IP_ADDRESS", "action": "allow" }
  ],
  "must_not_appear": [
    "AKIAIOSFODNN7EXAMPLE",
    "ghp_AbCdEfGhIjKlMnOpQrStUvWxYz0123456789"
  ]
}
